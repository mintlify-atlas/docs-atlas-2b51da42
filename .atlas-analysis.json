  "keyFeatures": [
    "Private staff authentication with invite-only onboarding",
    "Patient records with strict ownership via Row Level Security",
    "Clinical session drafts with autosave functionality",
    "Superadmin user management and invitation flow",
    "Session expiry warning UI",
    "Google OAuth and email/password support",
    "Next.js App Router with React Server Components",
    "PostgreSQL with RLS policies via Supabase"
  ],
  "publicApiSurface": [
    "POST /login — staff authentication",
    "GET /auth/callback — OAuth callback handler",
    "GET /patients — list and search patients",
    "GET /patients/[patientId] — patient detail view",
    "POST /patients/[patientId]/sessions/new — create clinical session draft",
    "GET /patients/[patientId]/sessions/[sessionId] — view/edit session",
    "GET /admin/users — superadmin user management",
    "GET /profile — user profile management",
    "Server Action: createPatient",
    "Server Action: updatePatient",
    "Server Action: createSessionDraft",
    "Server Action: completeSession",
    "Server Action: inviteUser"
  ]
}
